{
  "name": "greenlearn-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "vite --mode all --host 127.0.0.1 --port 5175",
    "dev:parent": "vite --mode parent --host 127.0.0.1 --port 5173",
    "dev:child": "vite --mode child --host 127.0.0.1 --port 5174",
    "build": "vite build",
    "build:all": "vite build --mode all --outDir dist-all",
    "build:parent": "vite build --mode parent --outDir dist-parent",
    "build:child": "vite build --mode child --outDir dist-child",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:all": "vite preview --mode all --outDir dist-all --host 127.0.0.1 --port 4175",
    "preview:parent": "vite preview --mode parent --outDir dist-parent --host 127.0.0.1 --port 4173",
    "preview:child": "vite preview --mode child --outDir dist-child --host 127.0.0.1 --port 4174"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
